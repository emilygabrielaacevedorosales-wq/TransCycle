{
  "name": "transcycle-backend",
  "version": "1.0.0",
  "description": "TransCycle & Health — API REST",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node ./node_modules/ts-node-dev/lib/bin.js --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node ./node_modules/ts-node/dist/bin.js tests/api.test.ts",
