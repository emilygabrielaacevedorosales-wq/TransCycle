# ── Base de datos ──────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/transcycle

# ── Servidor ───────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_de_64_bytes_minimo
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Cifrado AES-256 ────────────────────────────────
# Clave maestra del servidor (32 bytes en hex)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=cambia_esto_por_32_bytes_en_hex_64_chars

# ── Rate limiting ──────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080
